<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0D0F14">

    <!-- TOP TOOLBAR -->
    <LinearLayout android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="54dp"
        android:background="#161A23" android:orientation="horizontal"
        android:gravity="center_vertical" android:paddingStart="6dp"
        android:paddingEnd="6dp" android:elevation="6dp">

        <Button android:id="@+id/btnBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:text="&#8592;" android:textSize="20sp" android:textColor="#7A839E"
            android:background="@drawable/btn_ripple" android:padding="0dp"/>

        <Button android:id="@+id/btnForward"
            android:layout_width="40dp" android:layout_height="40dp"
            android:text="&#8594;" android:textSize="20sp" android:textColor="#7A839E"
            android:background="@drawable/btn_ripple" android:padding="0dp"
            android:layout_marginStart="2dp"/>

        <!-- URL Bar -->
        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="36dp" android:background="@drawable/url_bar_bg"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="10dp" android:paddingEnd="6dp"
            android:layout_marginStart="6dp" android:layout_marginEnd="6dp">

            <TextView android:id="@+id/lockIcon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="&#128274;" android:textSize="11sp" android:layout_marginEnd="4dp"/>

            <EditText android:id="@+id/urlInput"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="match_parent" android:background="@null"
                android:textColor="#E8ECF5" android:textSize="13sp"
                android:hint="Search or type URL" android:hintTextColor="#7A839E"
                android:singleLine="true" android:imeOptions="actionGo"
                android:inputType="textUri" android:selectAllOnFocus="true"/>

            <Button android:id="@+id/btnClear"
                android:layout_width="24dp" android:layout_height="24dp"
                android:text="&#215;" android:textSize="14sp" android:textColor="#7A839E"
                android:background="@null" android:padding="0dp" android:visibility="gone"/>
        </LinearLayout>

        <Button android:id="@+id/btnReload"
            android:layout_width="40dp" android:layout_height="40dp"
            android:text="&#8635;" android:textSize="18sp" android:textColor="#7A839E"
            android:background="@drawable/btn_ripple" android:padding="0dp"/>

        <Button android:id="@+id/btnMore"
            android:layout_width="40dp" android:layout_height="40dp"
            android:text="&#8942;" android:textSize="20sp" android:textColor="#7A839E"
            android:background="@drawable/btn_ripple" android:padding="0dp"
            android:layout_marginStart="2dp"/>
    </LinearLayout>

    <!-- PROGRESS BAR -->
    <ProgressBar android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="2dp"
        android:max="100" android:progressTint="#5B8AF7"
        android:progressBackgroundTint="#1E2433" android:visibility="gone"/>

    <!-- FIND IN PAGE BAR -->
    <LinearLayout android:id="@+id/findBar"
        android:layout_width="match_parent" android:layout_height="44dp"
        android:background="#1E2433" android:orientation="horizontal"
        android:gravity="center_vertical" android:paddingStart="8dp"
        android:paddingEnd="8dp" android:visibility="gone">

        <EditText android:id="@+id/findInput"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="32dp" android:background="@drawable/url_bar_bg"
            android:textColor="#E8ECF5" android:textSize="13sp"
            android:hint="Find in page…" android:hintTextColor="#7A839E"
            android:paddingStart="10dp" android:paddingEnd="10dp"
            android:singleLine="true" android:imeOptions="actionSearch"/>

        <TextView android:id="@+id/findCount"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#7A839E" android:textSize="12sp"
            android:paddingStart="6dp" android:paddingEnd="4dp"/>

        <Button android:id="@+id/findPrev" android:layout_width="36dp"
            android:layout_height="36dp" android:text="&#8743;" android:textSize="16sp"
            android:textColor="#5B8AF7" android:background="@null" android:padding="0dp"/>
        <Button android:id="@+id/findNext" android:layout_width="36dp"
            android:layout_height="36dp" android:text="&#8744;" android:textSize="16sp"
            android:textColor="#5B8AF7" android:background="@null" android:padding="0dp"/>
        <Button android:id="@+id/findClose" android:layout_width="36dp"
            android:layout_height="36dp" android:text="&#215;" android:textSize="18sp"
            android:textColor="#7A839E" android:background="@null" android:padding="0dp"/>
    </LinearLayout>

    <!-- WEBVIEW + SWIPE REFRESH -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <WebView android:id="@+id/webView"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:scrollbars="none"/>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- BOTTOM NAV BAR -->
    <LinearLayout android:id="@+id/bottomBar"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:background="#161A23" android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button android:id="@+id/btnHome" android:layout_width="0dp"
            android:layout_weight="1" android:layout_height="48dp"
            android:text="&#127968;" android:textSize="20sp"
            android:background="@null" android:padding="0dp"/>
        <Button android:id="@+id/btnBookmarks" android:layout_width="0dp"
            android:layout_weight="1" android:layout_height="48dp"
            android:text="&#11088;" android:textSize="18sp"
            android:background="@null" android:padding="0dp"/>
        <Button android:id="@+id/btnHistory" android:layout_width="0dp"
            android:layout_weight="1" android:layout_height="48dp"
            android:text="&#128336;" android:textSize="18sp"
            android:background="@null" android:padding="0dp"/>
        <Button android:id="@+id/btnShare" android:layout_width="0dp"
            android:layout_weight="1" android:layout_height="48dp"
            android:text="&#128279;" android:textSize="18sp"
            android:background="@null" android:padding="0dp"/>
        <Button android:id="@+id/btnAddBookmark" android:layout_width="0dp"
            android:layout_weight="1" android:layout_height="48dp"
            android:text="&#128278;" android:textSize="20sp"
            android:background="@null" android:padding="0dp"/>
    </LinearLayout>

    <!-- FULLSCREEN VIDEO CONTAINER -->
    <FrameLayout android:id="@+id/fullscreenContainer"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#000" android:visibility="gone"/>
</LinearLayout>
